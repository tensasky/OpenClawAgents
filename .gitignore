# OpenClaw Agents - Git Ignore

# 大数据文件
*.db
*.db-journal
*.sqlite
*.sqlite3

# 日志文件
logs/
*.log

# 临时文件
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/

# 系统文件
.DS_Store
Thumbs.db

# 敏感信息
config.ini
credentials.json
*.key
*.pem

# 但保留示例配置
!config.example.ini
*.db-shm
*.db-wal
*.backup.*
