{
  "name": "xifeng",
  "version": "1.0.0",
  "description": "西风 - 舆情与热点分析专家",
  "author": "财神爷",
  "commands": {
    "analyze": {
      "description": "执行热点分析",
      "script": "xifeng.py",
      "args": []
    },
    "report": {
      "description": "查看热点报告",
      "script": "report.py",
      "args": []
    },
    "test": {
      "description": "测试RSS连接",
      "script": "test_rss.py",
      "args": []
    }
  },
  "schedule": {
    "interval": "30m",
    "command": "analyze"
  },
  "config": {
    "rss_sources": [
      {
        "name": "财联社",
        "url": "https://www.cls.cn/telegraph",
        "type": "api",
        "enabled": true
      },
      {
        "name": "东方财富",
        "url": "https://finance.eastmoney.com/a/cywjh.html",
        "type": "html",
        "enabled": false
      }
    ],
    "llm": {
      "model": "moonshot/kimi-k2.5",
      "temperature": 0.3
    },
    "heat_threshold": {
      "high": 80,
      "medium": 40
    },
    "history_days": 15,
    "output_file": "hot_spots.json"
  }
}
